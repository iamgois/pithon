generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Apoiador {
  id                String   @id @default(uuid())
  nome              String
  email             String?  @unique
  senha             String?
  telefone          String?
  dataNascimento    String?
  cidade            String?
  bairro            String?
  profissao         String?
  assuntosInteresse String?
  hobbies           String?
  nivelApoio        String?
  canalComunicacao  String?
  codigoIndicacao   String   @unique
  indicadoPorCodigo String?
  totalIndicacoes   Int      @default(0)
  createdAt         DateTime @default(now())
  indicacoes        Indicacao[]
  leads             Lead[]
}

model Lead {
  id           String    @id @default(uuid())
  nome         String
  email        String    @unique
  telefone     String?
  origemCodigo String?
  intencaoApoio String
  createdAt    DateTime  @default(now())
  indicadoPor  Apoiador? @relation(fields: [origemCodigo], references: [codigoIndicacao])
  indicacao    Indicacao?
}

model Indicacao {
  id         String   @id @default(uuid())
  apoiadorId String
  leadId     String   @unique
  createdAt  DateTime @default(now())
  apoiador   Apoiador @relation(fields: [apoiadorId], references: [id])
  lead       Lead     @relation(fields: [leadId], references: [id])
}

model Admin {
  id       String @id @default(uuid())
  email    String @unique
  password String
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
